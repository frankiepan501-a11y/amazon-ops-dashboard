{
  "name": "AMZ - 亚马逊运营日看板刷新",
  "nodes": [
    {
      "parameters": {
        "rule": {
          "interval": [
            {
              "triggerAtHour": 9,
              "triggerAtMinute": 40
            },
            {
              "triggerAtHour": 13,
              "triggerAtMinute": 30
            }
          ]
        }
      },
      "id": "schedule",
      "name": "09:40 + 13:30 BJ",
      "type": "n8n-nodes-base.scheduleTrigger",
      "typeVersion": 1.1,
      "position": [
        0,
        0
      ]
    },
    {
      "parameters": {
        "method": "POST",
        "url": "={{$env.AMAZON_OPS_DASHBOARD_URL || 'https://amazon-ops-dashboard.zeabur.app'}}/dashboard/run?mode=commit",
        "sendHeaders": true,
        "headerParameters": {
          "parameters": [
            {
              "name": "Authorization",
              "value": "=Bearer {{$env.AMAZON_OPS_DASHBOARD_TOKEN}}"
            }
          ]
        },
        "options": {
          "timeout": 120000
        }
      },
      "id": "refresh",
      "name": "刷新日看板",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [
        240,
        0
      ]
    }
  ],
  "connections": {
    "09:40 + 13:30 BJ": {
      "main": [
        [
          {
            "node": "刷新日看板",
            "type": "main",
            "index": 0
          }
        ]
      ]
    }
  },
  "settings": {
    "executionOrder": "v1"
  }
}
